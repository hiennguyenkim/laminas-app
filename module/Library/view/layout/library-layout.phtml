$initials = function(string $name): string {
    $words = explode(' ', trim($name));
    $i = mb_strtoupper(mb_substr(end($words), 0, 1, 'UTF-8'), 'UTF-8');
    if (count($words) > 1) {
        $i = mb_strtoupper(mb_substr($words[0], 0, 1, 'UTF-8'), 'UTF-8') . mb_strtoupper(mb_substr(end($words), 0, 1, 'UTF-8'), 'UTF-8');
    }
    return $i;
};

