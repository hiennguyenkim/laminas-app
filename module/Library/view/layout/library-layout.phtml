    <script>
    function toggleChatbox() {
        document.getElementById('ai-chatbox').classList.toggle('active');
        if (document.getElementById('ai-chatbox').classList.contains('active')) {
            document.getElementById('chatbox-input').focus();
        }
    }

    async function sendChat() {
        const input = document.getElementById('chatbox-input');
        const msg = input.value.trim();
        if (!msg) return;

        // Add user msg
        const body = document.getElementById('chatbox-body');
        body.innerHTML += `<div class="chat-msg user-msg">${escapeHtml(msg)}</div>`;
        input.value = '';
        body.scrollTop = body.scrollHeight;

        // Show typing
        const typingId = 'typing-' + Date.now();
        body.innerHTML += `
            <div id="${typingId}" class="typing-indicator">
                <div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div>
            </div>`;
        body.scrollTop = body.scrollHeight;

        try {
            const userId = <?= $authUser ? $authUser['id'] : 'null' ?>;
            const res = await fetch('<?= $this->url('api/books/search') ?>'.replace('/search', '/chat'), {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: msg, user_id: userId })
            });
            const data = await res.json();
            
            document.getElementById(typingId).remove();
            
            let aiHtml = `<div class="chat-msg ai-msg">${escapeHtml(data.reply)}`;
            if (data.suggestions && data.suggestions.length > 0) {
                data.suggestions.forEach(book => {
                    aiHtml += `
                    <div class="book-suggestion" onclick="window.location.href='<?= $this->url('catalog') ?>?q=' + encodeURIComponent('${book.title}')">
                        <div style="font-weight:bold;color:var(--accent-purple)"><i class="bi bi-book"></i> ${escapeHtml(book.title)}</div>
                        <div style="color:var(--text-muted)">${escapeHtml(book.author)}</div>
                    </div>`;
                });
            }
            aiHtml += `</div>`;
            body.innerHTML += aiHtml;
            body.scrollTop = body.scrollHeight;

        } catch (e) {
            document.getElementById(typingId).remove();
            body.innerHTML += `<div class="chat-msg ai-msg" style="color:#ef4444">Lỗi kết nối. Vui lòng thử lại sau.</div>`;
        }
    }

    function escapeHtml(unsafe) {
        return (unsafe||'').replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
    }
    </script>
</body>
