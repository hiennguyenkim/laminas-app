<script>
(function () {
    'use strict';

    // ── Cấu hình ──────────────────────────────────────────
    const SEARCH_API   = '/api/books/search';
    const MIN_CHARS    = 1;          // Bắt đầu tìm từ 1 ký tự
    const DEBOUNCE_MS  = 280;        // Tránh spam request

    // ── DOM refs ──────────────────────────────────────────
    const searchInput    = document.getElementById('book-search-input');
    const hiddenBookId   = document.getElementById('book-id-hidden');
    const dropdown       = document.getElementById('book-dropdown');
    const clearBtn       = document.getElementById('clear-book-btn');
    const selectedCard   = document.getElementById('selected-book-card');
    const submitBtn      = document.getElementById('submit-btn');
    const borrowDateEl   = document.getElementById('borrow-date');
    const returnDateEl   = document.getElementById('return-date');

    // ── State ─────────────────────────────────────────────
    let debounceTimer   = null;
    let selectedBookId  = 0;
    let highlightIndex  = -1;

    // ── Khởi tạo ngày hợp lệ ──────────────────────────────
    if (borrowDateEl && returnDateEl) {
        borrowDateEl.addEventListener('change', function () {
            // Hạn trả phải sau hoặc bằng ngày mượn
            if (returnDateEl.value < borrowDateEl.value) {
                returnDateEl.value = borrowDateEl.value;
            }
            returnDateEl.min = borrowDateEl.value;

            // Kiểm tra không quá 30 ngày
            const borrow = new Date(borrowDateEl.value);
            const ret    = new Date(returnDateEl.value);
            const diff   = (ret - borrow) / 86400000;
            if (diff > 30) {
                const maxDate = new Date(borrow);
                maxDate.setDate(maxDate.getDate() + 30);
                returnDateEl.value = maxDate.toISOString().split('T')[0];
            }
        });
    }

    // ── Hàm debounce ──────────────────────────────────────
    function debounce(fn, ms) {
        return function (...args) {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(() => fn.apply(this, args), ms);
        };
    }

    // ── Hàm escape HTML ───────────────────────────────────
    function esc(str) {
        const d = document.createElement('div');
        d.textContent = str;
        return d.innerHTML;
    }

    // ── Highlight từ khóa trong text ──────────────────────
    function highlight(text, query) {
        if (! query) return esc(text);
        const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        const re = new RegExp('(' + escaped + ')', 'gi');
        return esc(text).replace(re, '<mark style="background:rgba(124,106,255,.25);color:inherit;border-radius:2px;padding:0 1px">$1</mark>');
    }

    // ── Render dropdown ───────────────────────────────────
    function renderDropdown(books, query) {
        if (books.length === 0) {
            dropdown.innerHTML = '<div class="search-no-result"><i class="bi bi-inbox"></i> Không tìm thấy sách nào phù hợp.</div>';
        } else {
            dropdown.innerHTML = books.map((b, idx) => `
                <div class="book-option" data-idx="${idx}" data-book='${JSON.stringify(b).replace(/'/g, "&#39;")}'>
                    <div class="book-option-icon"><i class="bi bi-book"></i></div>
                    <div class="book-option-info">
                        <div class="book-option-title">${highlight(b.title, query)}</div>
                        <div class="book-option-meta">${esc(b.author)}${b.isbn ? ' · ISBN: ' + esc(b.isbn) : ''} · ${esc(b.category)}</div>
                    </div>
                    <div class="book-option-qty">Còn ${b.quantity}</div>
                </div>
            `).join('');

            // Gán sự kiện click cho từng option
            dropdown.querySelectorAll('.book-option').forEach(el => {
                el.addEventListener('mousedown', function (e) {
                    e.preventDefault(); // Tránh blur input trước khi click xử lý xong
                    const book = JSON.parse(this.dataset.book);
                    selectBook(book);
                });
            });
        }
        dropdown.style.display = 'block';
        highlightIndex = -1;
    }

    // ── Chọn sách ─────────────────────────────────────────
    function selectBook(book) {
        selectedBookId          = book.id;
        hiddenBookId.value      = book.id;
        searchInput.value       = book.title;
        clearBtn.style.display  = 'inline-flex';
        dropdown.style.display  = 'none';

        // Hiển thị card thông tin sách
        document.getElementById('selected-title').textContent    = book.title;
        document.getElementById('selected-author').textContent   = book.author || '—';
        document.getElementById('selected-category').textContent = book.category || '—';
        document.getElementById('selected-qty').textContent      = 'Còn ' + book.quantity + ' cuốn';
        selectedCard.style.display = 'block';

        // Kích hoạt nút submit
        if (submitBtn) submitBtn.disabled = false;
    }

    // ── Xóa lựa chọn ──────────────────────────────────────
    function clearSelection() {
        selectedBookId         = 0;
        hiddenBookId.value     = '';
        searchInput.value      = '';
        clearBtn.style.display = 'none';
        selectedCard.style.display = 'none';
        dropdown.style.display = 'none';
        searchInput.focus();
    }

    // ── Gọi API tìm kiếm ──────────────────────────────────
    async function doSearch(query) {
        if (query.length < MIN_CHARS) {
            dropdown.style.display = 'none';
            return;
        }

        // Hiển thị loading
        dropdown.innerHTML = '<div class="search-loading"><i class="bi bi-arrow-repeat"></i> Đang tìm...</div>';
        dropdown.style.display = 'block';

        try {
            const url  = `${SEARCH_API}?q=${encodeURIComponent(query)}&available_only=1&limit=20`;
            const resp = await fetch(url, { headers: { 'Accept': 'application/json' } });
            if (! resp.ok) throw new Error('HTTP ' + resp.status);
            const books = await resp.json();
            renderDropdown(books, query);
        } catch (err) {
            dropdown.innerHTML = '<div class="search-no-result"><i class="bi bi-exclamation-triangle"></i> Lỗi kết nối. Thử lại.</div>';
            console.error('Book search error:', err);
        }
    }

    // ── Sự kiện input ──────────────────────────────────────
    const debouncedSearch = debounce(doSearch, DEBOUNCE_MS);

    searchInput.addEventListener('input', function () {
        const q = this.value.trim();
        if (selectedBookId > 0 && q !== searchInput.dataset.selectedTitle) {
            // User đã xóa/thay đổi sau khi chọn → reset
            hiddenBookId.value         = '';
            selectedBookId             = 0;
            clearBtn.style.display     = 'none';
            selectedCard.style.display = 'none';
        }
        debouncedSearch(q);
    });

    // ── Điều hướng bằng bàn phím ──────────────────────────
    searchInput.addEventListener('keydown', function (e) {
        const options = dropdown.querySelectorAll('.book-option');
        if (! options.length) return;

        if (e.key === 'ArrowDown') {
            e.preventDefault();
            highlightIndex = Math.min(highlightIndex + 1, options.length - 1);
        } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            highlightIndex = Math.max(highlightIndex - 1, -1);
        } else if (e.key === 'Enter' && highlightIndex >= 0) {
            e.preventDefault();
            options[highlightIndex].dispatchEvent(new Event('mousedown'));
            return;
        } else if (e.key === 'Escape') {
            dropdown.style.display = 'none';
            return;
        } else {
            return;
        }

        options.forEach((o, i) => o.classList.toggle('highlighted', i === highlightIndex));
        if (highlightIndex >= 0) options[highlightIndex].scrollIntoView({ block: 'nearest' });
    });

    // ── Ẩn dropdown khi click ra ngoài ───────────────────
    document.addEventListener('click', function (e) {
        if (! e.target.closest('#book-search-wrap')) {
            dropdown.style.display = 'none';
        }
    });

    // ── Nút xóa lựa chọn ─────────────────────────────────
    if (clearBtn) clearBtn.addEventListener('click', clearSelection);

    // ── Prefill khi có ?book_id=... trong URL ─────────────
    (function prefillFromUrl() {
        const params = new URLSearchParams(window.location.search);
        const preId  = parseInt(params.get('book_id') || '0', 10);
        if (preId > 0) {
            fetch(`/api/books/${preId}`, { headers: { 'Accept': 'application/json' } })
                .then(r => r.json())
                .then(book => {
                    if (book && book.id && book.status === 'available') {
                        selectBook(book);
                    }
                })
                .catch(() => {});
        }
    })();

    // ── Validation trước khi submit ───────────────────────
    document.getElementById('borrow-form').addEventListener('submit', function (e) {
        if (! hiddenBookId.value || parseInt(hiddenBookId.value, 10) <= 0) {
            e.preventDefault();
            searchInput.style.outline = '2px solid #ef4444';
            searchInput.focus();
            // Hiển thị thông báo
            let err = document.getElementById('book-search-error');
            if (! err) {
                err = document.createElement('div');
                err.id = 'book-search-error';
                err.style.cssText = 'color:#ef4444;font-size:12px;margin-top:5px';
                err.textContent   = 'Vui lòng chọn một cuốn sách từ danh sách.';
                document.getElementById('book-search-wrap').after(err);
            }
            return;
        }
        // Validate ngày
        if (returnDateEl && borrowDateEl && returnDateEl.value < borrowDateEl.value) {
            e.preventDefault();
            returnDateEl.style.outline = '2px solid #ef4444';
            returnDateEl.focus();
        }
    });

    // ── Khởi tạo: ẩn submit nếu chưa chọn sách ──────────
    if (submitBtn && ! hiddenBookId.value) {
        // Không disable hoàn toàn vì Laminas validation sẽ bắt lỗi,
        // nhưng JS validation sẽ chặn trước khi submit.
    }

})();
</script>
