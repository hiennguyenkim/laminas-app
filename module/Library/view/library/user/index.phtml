$avatarColors = ['#7c6aff','#22c55e','#f97316','#ec4899','#3b82f6','#14b8a6','#ef4444','#fbbf24'];
$initials = function(string $name): string {
    $words = explode(' ', trim($name));
    if (count($words) >= 2) return strtoupper(substr($words[0], 0, 1).substr(end($words), 0, 1));
    return strtoupper(substr($name, 0, 2));
};
