        <a href="<?= $this->url('library/auth', ['action' => 'register']) ?>" class="login-footer-link">Đăng ký</a>
    </p>
    <div class="login-copyright">
        © 2026 Bản quyền thuộc về <span class="login-footer-link">Thư Viện HDPE</span>
    </div>
</div>