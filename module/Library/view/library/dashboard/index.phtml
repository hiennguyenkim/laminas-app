<script>
<?php
$monthlyStats  = $monthlyStats ?? ['borrow' => array_fill(0, 12, 0), 'return' => array_fill(0, 12, 0)];
$borrowData    = json_encode(array_values($monthlyStats['borrow']));
$returnData    = json_encode(array_values($monthlyStats['return']));

// Category chart
$catColors = ['#7c6aff','#22c55e','#f97316','#ec4899','#3b82f6','#14b8a6','#fbbf24','#ef4444'];
$categoryStats = $categoryStats ?? [];
$catLabels = json_encode(array_keys($categoryStats));
$catData   = json_encode(array_values($categoryStats));
$catColorsUsed = json_encode(array_slice($catColors, 0, count($categoryStats)));
?>
// Line Chart
(function() {
    const ctx = document.getElementById('borrowChart');
    if (!ctx) return;
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: ['T1','T2','T3','T4','T5','T6','T7','T8','T9','T10','T11','T12'],
            datasets: [{
                label: 'Mượn', data: <?= $borrowData ?>,
                borderColor: '#7c6aff', backgroundColor: 'rgba(124,106,255,0.12)',
                fill: true, tension: 0.45, pointRadius: 3, borderWidth: 2.5
            },{
                label: 'Trả', data: <?= $returnData ?>,
                borderColor: '#22c55e', backgroundColor: 'rgba(34,197,94,0.08)',
                fill: true, tension: 0.45, pointRadius: 3, borderWidth: 2.5
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { color: '#5a6282', font: { size: 11 } } },
                y: { grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { color: '#5a6282', font: { size: 11 }, precision: 0 } }
            }
        }
    });
})();

// Donut Chart
(function() {
    const ctx = document.getElementById('categoryChart');
    if (!ctx) return;
    const labels  = <?= $catLabels ?>;
    const data    = <?= $catData ?>;
    const colors  = <?= $catColorsUsed ?>;
    if (!data.length) return;
    new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: labels,
            datasets: [{
                data: data,
                backgroundColor: colors,
                borderWidth: 0, hoverOffset: 6
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false, cutout: '68%',
            plugins: { legend: { display: false }, tooltip: { enabled: true } }
        }
    });
})();
</script>
